# Bedrock Chat Configuration
# Copy this file to .env and customize

# Server
BEDROCK_CHAT_HOST=127.0.0.1
BEDROCK_CHAT_PORT=8080
BEDROCK_CHAT_DEBUG=false

# Data directory (SQLite database, model config, encryption salt)
BEDROCK_CHAT_DATA_DIR=./data

# AWS Configuration
BEDROCK_CHAT_AWS_REGION=us-east-1
BEDROCK_CHAT_AWS_PROFILE=

# Default model
BEDROCK_CHAT_DEFAULT_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Limits
BEDROCK_CHAT_MAX_MESSAGE_LENGTH=50000
BEDROCK_CHAT_MAX_CONTEXT_MESSAGES=50

# CORS (comma-separated origins)
# BEDROCK_CHAT_CORS_ORIGINS=["http://127.0.0.1:8080"]

# Encryption passphrase (optional — prompted on startup if not set)
# BEDROCK_CHAT_PASSPHRASE=
